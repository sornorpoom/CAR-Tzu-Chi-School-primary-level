function doGet(e) {
  return HtmlService.createTemplateFromFile('index')
      .evaluate()
      .setTitle('ระบบสารสนเทศสรุปผลการสะท้อนคิดวิจัยในชั้นเรียน - รร.ชื่อจีนเชียงใหม่')
      .setSandboxMode(HtmlService.SandboxMode.IFRAME)
      .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL)
      .addMetaTag('viewport', 'width=device-width, initial-scale=1');
}

function readSheetData(sheet) {
  if (!sheet) return [];
  var data = sheet.getDataRange().getValues();
  if (!data || data.length <= 1) return [];
  var headers = data[0];
  for (var h = 0; h < headers.length; h++) {
    headers[h] = headers[h].toString().trim();
  }
  var jsonData = [];
  for (var i = 1; i < data.length; i++) {
    var obj = {};
    var row = data[i];
    var hasData = false;
    for (var j = 0; j < headers.length; j++) {
      var val = row[j];
      obj[headers[j]] = val;
      if (val !== null && val !== '') {
        hasData = true;
      }
    }
    if (hasData) {
      jsonData.push(obj);
    }
  }
  return jsonData;
}

function getDashboardData() {
  var result = {
    primary: [],
    secondary: []
  };
  
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    if (ss) {
      var sheets = ss.getSheets();
      var primarySheet = null;
      var secondarySheet = null;
      
      for (var i = 0; i < sheets.length; i++) {
        var name = sheets[i].getName();
        if (name.indexOf("ประถม") !== -1 || name.indexOf("เพื่อนครู") !== -1) {
          primarySheet = sheets[i];
        } else if (name.indexOf("มัธยม") !== -1 || name.indexOf("Live") !== -1) {
          secondarySheet = sheets[i];
        }
      }
      
      if (!primarySheet && sheets.length > 0) primarySheet = sheets[0];
      if (!secondarySheet && sheets.length > 1) secondarySheet = sheets[1];
      
      if (primarySheet) {
        result.primary = readSheetData(primarySheet);
      }
      if (secondarySheet) {
        result.secondary = readSheetData(secondarySheet);
      }
    }
  } catch (e) {
    Logger.log('SpreadsheetApp not available: ' + e.message);
  }
  
  // Fallback to Embedded Demo Data if still empty
  if (result.primary.length === 0) {
    result.primary = JSON.parse(getPrimaryDemoData());
  }
  if (result.secondary.length === 0) {
    result.secondary = JSON.parse(getSecondaryDemoData());
  }
  
  return JSON.stringify(result);
}

